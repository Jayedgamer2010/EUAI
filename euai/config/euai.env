# EUAI Environment Configuration
# This file is used by runner.py to locate model and config files

# Model path (relative to project root)
MODEL_PATH=models/qwen2.5-0.5b.gguf

# Config directory
CONFIG_DIR=config/

# Inference settings
MAX_TOKENS=200
TEMPERATURE=0.8
TOP_K=40
TOP_P=0.95
REPEAT_PENALTY=1.15

# Optional: Cloudflare tunnel
# CLOUDFLARE_TUNNEL_TOKEN=your_token_here
# CLOUDFLARE_HOSTNAME=euaiweb.yourdomain.com
